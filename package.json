{
  "name": "printget-shop-manager",
  "private": true,
  "version": "1.1.25",
  "description": "PrintGet Shop Manager — desktop app for print shop partners",
  "author": "PrintGet",
  "repository": "https://github.com/air8800/desktop-app-legacy-build-windows-7-8",
  "license": "UNLICENSED",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs",
    "predist": "npm run icons",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:preview": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win",
    "dist:x64": "npm run build && electron-builder --win --x64",
    "dist:ia32": "npm run build && electron-builder --win --ia32",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir",
    "electron:build": "npm run dist"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.5.0",
    "@supabase/supabase-js": "^2.39.0",
    "electron-is-dev": "^2.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.344.0",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "qrcode": "^1.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.21.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^22.3.27",
    "electron-builder": "^24.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.35",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.printget.shopmanager",
    "productName": "PrintGet Shop Manager Legacy",
    "copyright": "Copyright © 2026 PrintGet",
    "artifactName": "PrintGet-Shop-Manager-Legacy-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "air8800",
        "repo": "desktop-app-legacy-build-windows-7-8",
        "releaseType": "release"
      }
    ],
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/test_*",
      "!electron/**/*.pdf",
      "!electron/diagnose.js",
      "!electron/**/*.txt"
    ],
    "extraResources": [
      {
        "from": "./extraResources/",
        "to": "extraResources",
        "filter": [
          "**/*",
          "!**/test pdf.pdf",
          "!**/Examples/**",
          "!**/InstallLog/**",
          "!**/coverpages/**",
          "!**/AttachmentPlaceholders/**",
          "!**/unins000.*",
          "!**/License.txt",
          "!**/ReadMe.txt",
          "!**/PDFsharp License.txt",
          "!**/2printer-install.ini",
          "!**/ed32/**",
          "!**/ed64/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "squirrel",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico",
      "publisherName": "PrintGet",
      "legalTrademarks": "PrintGet Shop Manager",
      "requestedExecutionLevel": "asInvoker"
    },
    "squirrelWindows": {
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "build/icons/icon.png",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "build/icons"
    },
    "protocols": [
      {
        "name": "PrintGet OAuth",
        "schemes": [
          "printget"
        ]
      }
    ]
  }
}
